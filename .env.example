# Copy this to .env and fill in your values
# Never commit .env to GitHub

OPENAI_API_KEY=sk-...

# Optional: real Jira integration
# Leave blank to run in mock mode (default for demos)
JIRA_BASE_URL=https://yourcompany.atlassian.net
JIRA_EMAIL=you@email.com
JIRA_API_TOKEN=your-jira-api-token
JIRA_PROJECT_KEY=IT

# Optional: Slack notifications on SLA breach
# Leave blank to skip Slack alerts
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/...

# Optional: email alerts via SMTP
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=you@gmail.com
SMTP_PASSWORD=your-app-password
ALERT_RECIPIENTS=manager@company.com,lead@company.com
